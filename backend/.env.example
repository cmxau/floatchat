# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: OpenAI API key (used for GPT-4o-mini SQL generation)
OPENAI_API_KEY=sk-...

# PostgreSQL connection (default matches local setup)
DATABASE_URL=postgresql://localhost/floatchat

# Optional: Ollama runs locally, no key needed
# Mistral, QWEN 2.5 Coder, and LLaMA 3.2 are served via Ollama at localhost:11434
